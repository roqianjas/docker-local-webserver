# ============================================================
# Docker Local Webserver — Environment Variables
# ============================================================
# Copy file ini menjadi .env, lalu edit sesuai kebutuhan.
#   cp .env.example .env
# Setelah edit, restart container yang terkait.
# ============================================================

# === TIMEZONE ===
TZ=Asia/Jakarta

# === MARIADB ===
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=homestead
MYSQL_USER=homestead
MYSQL_PASSWORD=secret

# === PHP DEFAULT VERSION ===
# Versi PHP yang digunakan oleh php-cron dan php-worker
PHP_DEFAULT=8.4

# === XDEBUG ===
# Set ke "true" untuk mengaktifkan Xdebug (memperlambat PHP, gunakan saat debug saja)
# Setelah mengubah, restart PHP container: docker compose restart php84
XDEBUG_ENABLED=false

# === QUEUE WORKER ===
# Project yang dijalankan queue worker (nama folder di sites/)
WORKER_PROJECT=default
# Queue connection: redis, database, sync
WORKER_QUEUE_CONNECTION=redis

# === PORTS (ubah jika konflik) ===
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81
NGINX_PORT=8000
MARIADB_PORT=3306
PHPMYADMIN_PORT=8080
REDIS_PORT=6379
REDISINSIGHT_PORT=8001
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
DOCKGE_PORT=5001
DOZZLE_PORT=9999
